{
  "log": {
    "level": "info",
    "timestamp": true
  },
  "dns": {
    "servers": [
      {
        "tag": "remote",
        "type": "https",
        "server": "1.1.1.1",
        "server_port": 443,
        "path": "/dns-query"
      },
      {
        "tag": "local",
        "type": "local"
      }
    ],
    "final": "remote",
    "strategy": "prefer_ipv4"
  },
  "inbounds": [
    {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "127.0.0.1",
      "listen_port": 2080
    }
  ],
  "outbounds": [
    {
      "type": "selector",
      "tag": "select",
      "outbounds": ["auto", "my-server"],
      "default": "auto"
    },
    {
      "type": "urltest",
      "tag": "auto",
      "outbounds": ["my-server"],
      "url": "http://cp.cloudflare.com/generate_204",
      "interval": "5m0s",
      "tolerance": 100
    },
    {
      "type": "hysteria2",
      "tag": "my-server",
      "server": "YOUR_SERVER_IP",
      "server_port": 443,
      "up_mbps": 100,
      "down_mbps": 100,
      "password": "YOUR_PASSWORD",
      "tls": {
        "enabled": true,
        "server_name": "YOUR_DOMAIN",
        "alpn": "h3"
      }
    },
    {
      "type": "direct",
      "tag": "direct"
    }
  ],
  "route": {
    "rules": [
      { "action": "sniff" },
      { "protocol": "dns", "action": "hijack-dns" },
      { "ip_is_private": true, "outbound": "direct" }
    ],
    "final": "select",
    "auto_detect_interface": true,
    "default_domain_resolver": "local"
  }
}
